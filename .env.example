# ============================================
# CONVEX — Backend em tempo real
# Obtido em: dashboard.convex.dev → seu projeto
# ============================================
CONVEX_DEPLOYMENT=dev:seu-projeto-aqui
NEXT_PUBLIC_CONVEX_URL=https://seu-projeto.convex.cloud

# ============================================
# CLERK — Autenticação
# Obtido em: dashboard.clerk.com → API Keys
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_COLE_AQUI
CLERK_SECRET_KEY=sk_test_COLE_AQUI
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ============================================
# CLOUDFLARE R2 — Storage de fotos
# Obtido em: dash.cloudflare.com → R2 → API Tokens
# ============================================
CLOUDFLARE_ACCOUNT_ID=COLE_AQUI
CLOUDFLARE_R2_ACCESS_KEY_ID=COLE_AQUI
CLOUDFLARE_R2_SECRET_ACCESS_KEY=COLE_AQUI
CLOUDFLARE_R2_BUCKET_NAME=food-truck-alert
CLOUDFLARE_R2_PUBLIC_URL=https://pub-COLE_AQUI.r2.dev

# ============================================
# MERCADO PAGO — Pagamentos
# Obtido em: mercadopago.com.br/developers → Suas integrações
# ============================================
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-COLE_AQUI
MERCADO_PAGO_WEBHOOK_SECRET=COLE_AQUI
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=APP_USR-COLE_AQUI

# ============================================
# GOOGLE MAPS — Mapa e geolocalização
# Obtido em: console.cloud.google.com → APIs & Services → Credentials
# Ativar: Maps SDK Android, Maps SDK iOS, Maps Static API
# ============================================
NEXT_PUBLIC_GOOGLE_MAPS_KEY=COLE_AQUI
EXPO_PUBLIC_GOOGLE_MAPS_KEY=COLE_AQUI

# ============================================
# APP — URL pública (definida após deploy no Vercel)
# ============================================
NEXT_PUBLIC_APP_URL=https://SEU-DOMINIO.vercel.app

# ============================================
# EXPO — Mobile (apenas para build local)
# ============================================
EXPO_PUBLIC_CONVEX_URL=https://seu-projeto.convex.cloud
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_COLE_AQUI
# ID do truck para a tela da cozinha (opcional)
# EXPO_PUBLIC_KITCHEN_TRUCK_ID=
