{
  "expo": {
    "name": "Food Pronto",
    "slug": "food-truck-alert",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "foodtruckalert",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "bundleIdentifier": "com.foodtruckalert",
      "associatedDomains": [
        "applinks:SEU-DOMINIO.vercel.app"
      ],
      "supportsTablet": false
    },
    "android": {
      "package": "com.foodtruckalert",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "SEU-DOMINIO.vercel.app",
              "pathPrefix": "/menu"
            },
            {
              "scheme": "https",
              "host": "SEU-DOMINIO.vercel.app",
              "pathPrefix": "/truck"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Precisamos da sua localização para mostrar food trucks próximos."
        }
      ]
    ]
  }
}
